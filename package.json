{
  "name": "task-loop-orchestrator",
  "version": "0.1.0",
  "description": "AI role-split closed-loop task orchestrator MVP.",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "bin": {
    "task-loop-orchestrator": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node -e \"const fs = require('node:fs'); if (fs.existsSync('dist/cli.js')) fs.chmodSync('dist/cli.js', 0o755);\"",
    "prepack": "pnpm run build",
    "package:smoke": "node scripts/package-smoke.mjs",
    "release:check": "node scripts/release-check.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "pnpm run typecheck",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "schemas",
    "orchestrator.config.example.json"
  ],
  "devDependencies": {
    "@types/node": "^24.0.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
