{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jiahlee-work/task-loop-orchestrator/schemas/cli-json.schema.json",
  "title": "task-loop-orchestrator CLI JSON response",
  "description": "Common metadata envelope for task-loop-orchestrator CLI --json responses. Command-specific payload fields are allowed at the top level for compatibility.",
  "type": "object",
  "required": ["schemaVersion", "command", "createdAt"],
  "properties": {
    "schemaVersion": {
      "const": 1,
      "description": "CLI JSON schema version."
    },
    "command": {
      "type": "string",
      "enum": [
        "init",
        "doctor",
        "run",
        "resume",
        "status",
        "checkpoint",
        "checks",
        "pr-plan",
        "pr-exec",
        "approve-pr"
      ],
      "description": "CLI command that produced the response."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp for the JSON response. Legacy payload timestamps may be preserved."
    }
  },
  "$defs": {
    "runStatus": {
      "type": "string",
      "enum": ["created", "running", "completed", "blocked", "failed"]
    },
    "permissionMode": {
      "type": "string",
      "enum": ["read", "write", "maintainer"]
    },
    "subtaskCounts": {
      "type": "object",
      "required": ["pending", "active", "completed", "blocked", "failed", "total"],
      "properties": {
        "pending": {
          "type": "integer",
          "minimum": 0
        },
        "active": {
          "type": "integer",
          "minimum": 0
        },
        "completed": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "runReportTask": {
      "type": "object",
      "required": ["id", "title", "acceptanceCriteria"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "acceptanceCriteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "runReportPayload": {
      "type": "object",
      "required": ["runId", "status", "iterations", "permissionMode", "task", "counts", "savedPath", "run"],
      "properties": {
        "runId": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/runStatus"
        },
        "iterations": {
          "type": "integer",
          "minimum": 0
        },
        "permissionMode": {
          "$ref": "#/$defs/permissionMode"
        },
        "task": {
          "$ref": "#/$defs/runReportTask"
        },
        "counts": {
          "$ref": "#/$defs/subtaskCounts"
        },
        "savedPath": {
          "type": "string"
        },
        "run": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "command": {
            "enum": ["run", "resume"]
          }
        },
        "required": ["command"]
      },
      "then": {
        "$ref": "#/$defs/runReportPayload"
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "status"
          }
        },
        "required": ["command", "runId"]
      },
      "then": {
        "$ref": "#/$defs/runReportPayload"
      }
    }
  ],
  "additionalProperties": true
}
