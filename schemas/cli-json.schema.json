{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jiahlee-work/task-loop-orchestrator/schemas/cli-json.schema.json",
  "title": "task-loop-orchestrator CLI JSON response",
  "description": "Common metadata envelope for task-loop-orchestrator CLI --json responses. Command-specific payload fields are allowed at the top level for compatibility.",
  "type": "object",
  "required": ["schemaVersion", "command", "createdAt"],
  "properties": {
    "schemaVersion": {
      "const": 1,
      "description": "CLI JSON schema version."
    },
    "command": {
      "type": "string",
      "enum": [
        "init",
        "doctor",
        "run",
        "resume",
        "status",
        "checkpoint",
        "checks",
        "pr-plan",
        "pr-exec",
        "approve-pr",
        "execution-audit"
      ],
      "description": "CLI command that produced the response."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp for the JSON response. Legacy payload timestamps may be preserved."
    }
  },
  "$defs": {
    "runStatus": {
      "type": "string",
      "enum": ["created", "running", "completed", "blocked", "failed"]
    },
    "permissionMode": {
      "type": "string",
      "enum": ["read", "write", "maintainer"]
    },
    "doctorStatus": {
      "type": "string",
      "enum": ["pass", "warn", "fail"]
    },
    "doctorSuggestion": {
      "type": "object",
      "required": ["label", "command", "reason", "destructive"],
      "properties": {
        "label": {
          "type": "string"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        },
        "destructive": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "doctorCheck": {
      "type": "object",
      "required": ["id", "status", "summary"],
      "properties": {
        "id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/doctorStatus"
        },
        "summary": {
          "type": "string"
        },
        "details": {},
        "recommendedAction": {
          "type": "string"
        },
        "suggestions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/doctorSuggestion"
          }
        }
      },
      "additionalProperties": true
    },
    "doctorPayload": {
      "type": "object",
      "required": ["status", "rootDir", "githubMode", "checks"],
      "properties": {
        "status": {
          "$ref": "#/$defs/doctorStatus"
        },
        "rootDir": {
          "type": "string"
        },
        "githubMode": {
          "type": "string",
          "enum": ["none", "gh-cli"]
        },
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/doctorCheck"
          }
        }
      },
      "additionalProperties": true
    },
    "initFileStatus": {
      "type": "string",
      "enum": ["created", "updated", "skipped"]
    },
    "initFileResult": {
      "type": "object",
      "required": ["path", "status"],
      "properties": {
        "path": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/initFileStatus"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "initPayload": {
      "type": "object",
      "required": ["rootDir", "force", "files"],
      "properties": {
        "rootDir": {
          "type": "string"
        },
        "force": {
          "type": "boolean"
        },
        "files": {
          "type": "object",
          "required": ["config", "gitignore"],
          "properties": {
            "config": {
              "$ref": "#/$defs/initFileResult"
            },
            "gitignore": {
              "$ref": "#/$defs/initFileResult"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "githubCheckStatus": {
      "type": "string",
      "enum": ["success", "pending", "failure", "error", "not_found", "unknown"]
    },
    "checkpointStatus": {
      "type": "string",
      "enum": ["clean", "needs_attention", "blocked"]
    },
    "checkpointCounts": {
      "type": "object",
      "required": ["completed", "blocked", "pending", "active", "failed"],
      "properties": {
        "completed": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        },
        "pending": {
          "type": "integer",
          "minimum": 0
        },
        "active": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "checkDetail": {
      "type": "object",
      "required": ["name", "status"],
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/githubCheckStatus"
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "checkpointCiCheck": {
      "type": "object",
      "required": ["status", "summary", "source"],
      "properties": {
        "status": {
          "anyOf": [
            {
              "$ref": "#/$defs/githubCheckStatus"
            },
            {
              "const": "not_run"
            }
          ]
        },
        "summary": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": ["placeholder", "github"]
        },
        "details": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/checkDetail"
          }
        }
      },
      "additionalProperties": true
    },
    "maintainerActionCandidate": {
      "type": "object",
      "required": ["action", "label", "reason", "decisionReady"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["push", "merge_pr", "jira_transition", "release", "create_pr"]
        },
        "label": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "decisionReady": {
          "const": true
        }
      },
      "additionalProperties": true
    },
    "prPlanCommandCandidate": {
      "type": "object",
      "required": ["action", "command", "reason", "decisionReady"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["create_branch", "commit", "push", "create_pr"]
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        },
        "decisionReady": {
          "const": true
        }
      },
      "additionalProperties": true
    },
    "approvalPlanSnapshot": {
      "type": "object",
      "required": ["planTitle", "baseBranch", "sourceBranchHint", "blockedReasons", "commandCandidateActions"],
      "properties": {
        "planTitle": {
          "type": "string"
        },
        "baseBranch": {
          "type": "string"
        },
        "sourceBranchHint": {
          "type": "string"
        },
        "blockedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commandCandidateActions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["create_branch", "commit", "push", "create_pr"]
          }
        }
      },
      "additionalProperties": true
    },
    "approvalRecord": {
      "type": "object",
      "required": ["id", "scope", "planId", "runId", "status", "createdAt"],
      "properties": {
        "id": {
          "type": "string"
        },
        "scope": {
          "const": "pr_execution"
        },
        "planId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "checkpointId": {
          "type": "string"
        },
        "planSnapshot": {
          "$ref": "#/$defs/approvalPlanSnapshot"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"]
        },
        "approvedBy": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "approvePrPayload": {
      "$ref": "#/$defs/approvalRecord"
    },
    "executionIntentStatus": {
      "type": "string",
      "enum": ["created", "blocked", "expired"]
    },
    "executionTraceStatus": {
      "type": "string",
      "enum": ["planned", "blocked"]
    },
    "executionTracePolicyDecision": {
      "type": "string",
      "enum": ["dry_run_planned", "blocked"]
    },
    "executionActionSummary": {
      "type": "object",
      "required": ["action", "count"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["create_branch", "commit", "push", "create_pr"]
        },
        "count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "executionAuditIntentReport": {
      "type": "object",
      "required": [
        "id",
        "runId",
        "planId",
        "approvalId",
        "status",
        "actor",
        "createdAt",
        "expiresAt",
        "targetRef",
        "baseBranch",
        "sourceBranch",
        "permissionMode",
        "policyVersion",
        "commandCandidateCount",
        "commandCandidateActions",
        "commandActionSummary",
        "blockedReasonCount",
        "blockedReasons",
        "executionEnabled",
        "writeExecution"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "planId": {
          "type": "string"
        },
        "approvalId": {
          "type": "string"
        },
        "checkpointId": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/executionIntentStatus"
        },
        "actor": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "targetRef": {
          "type": "string"
        },
        "baseBranch": {
          "type": "string"
        },
        "sourceBranch": {
          "type": "string"
        },
        "permissionMode": {
          "$ref": "#/$defs/permissionMode"
        },
        "policyVersion": {
          "type": "string"
        },
        "commandCandidateCount": {
          "type": "integer",
          "minimum": 0
        },
        "commandCandidateActions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["create_branch", "commit", "push", "create_pr"]
          }
        },
        "commandActionSummary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/executionActionSummary"
          }
        },
        "blockedReasonCount": {
          "type": "integer",
          "minimum": 0
        },
        "blockedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "executionEnabled": {
          "const": false
        },
        "writeExecution": {
          "const": "disabled"
        }
      },
      "additionalProperties": true
    },
    "executionAuditTraceReport": {
      "type": "object",
      "required": [
        "id",
        "intentId",
        "runId",
        "planId",
        "approvalId",
        "action",
        "argv",
        "reason",
        "status",
        "policyVersion",
        "policyDecision",
        "blockedReasonCount",
        "blockedReasons",
        "createdAt",
        "executionEnabled",
        "writeExecution",
        "hasExecutionResults"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "intentId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "planId": {
          "type": "string"
        },
        "approvalId": {
          "type": "string"
        },
        "checkpointId": {
          "type": "string"
        },
        "action": {
          "type": "string",
          "enum": ["create_branch", "commit", "push", "create_pr"]
        },
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/executionTraceStatus"
        },
        "policyVersion": {
          "type": "string"
        },
        "policyDecision": {
          "$ref": "#/$defs/executionTracePolicyDecision"
        },
        "blockedReasonCount": {
          "type": "integer",
          "minimum": 0
        },
        "blockedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "executionEnabled": {
          "const": false
        },
        "writeExecution": {
          "const": "disabled"
        },
        "hasExecutionResults": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "executionAuditPayload": {
      "type": "object",
      "required": [
        "intent",
        "traces",
        "traceCount",
        "plannedTraceCount",
        "blockedTraceCount",
        "traceActionSummary",
        "blockedReasonCount",
        "blockedReasons",
        "mismatchedTraceCount",
        "mismatchedTraceIds",
        "executionEnabled",
        "writeExecution",
        "hasExecutionResults"
      ],
      "properties": {
        "intent": {
          "$ref": "#/$defs/executionAuditIntentReport"
        },
        "traces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/executionAuditTraceReport"
          }
        },
        "traceCount": {
          "type": "integer",
          "minimum": 0
        },
        "plannedTraceCount": {
          "type": "integer",
          "minimum": 0
        },
        "blockedTraceCount": {
          "type": "integer",
          "minimum": 0
        },
        "traceActionSummary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/executionActionSummary"
          }
        },
        "blockedReasonCount": {
          "type": "integer",
          "minimum": 0
        },
        "blockedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mismatchedTraceCount": {
          "type": "integer",
          "minimum": 0
        },
        "mismatchedTraceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "executionEnabled": {
          "const": false
        },
        "writeExecution": {
          "const": "disabled"
        },
        "hasExecutionResults": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "executionAuditErrorPayload": {
      "type": "object",
      "required": [
        "status",
        "errorCode",
        "message",
        "intent",
        "executionEnabled",
        "writeExecution",
        "hasExecutionResults"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_found", "error"]
        },
        "errorCode": {
          "type": "string",
          "enum": [
            "execution_intent_not_found",
            "execution_audit_missing_intent",
            "invalid_execution_intent_file",
            "invalid_execution_trace_file"
          ]
        },
        "message": {
          "type": "string"
        },
        "intentId": {
          "type": "string"
        },
        "intent": {
          "const": null
        },
        "details": {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["execution_intent", "execution_trace"]
            }
          },
          "additionalProperties": true
        },
        "executionEnabled": {
          "const": false
        },
        "writeExecution": {
          "const": "disabled"
        },
        "hasExecutionResults": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "executionAuditListPayload": {
      "type": "object",
      "required": [
        "status",
        "bundleCount",
        "bundles",
        "executionEnabled",
        "writeExecution",
        "hasExecutionResults"
      ],
      "properties": {
        "status": {
          "const": "ok"
        },
        "bundleCount": {
          "type": "integer",
          "minimum": 0
        },
        "bundles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/executionAuditPayload"
          }
        },
        "executionEnabled": {
          "const": false
        },
        "writeExecution": {
          "const": "disabled"
        },
        "hasExecutionResults": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "executionAuditResponsePayload": {
      "type": "object",
      "required": ["executionEnabled", "writeExecution", "hasExecutionResults"],
      "properties": {
        "executionEnabled": {
          "const": false
        },
        "writeExecution": {
          "const": "disabled"
        },
        "hasExecutionResults": {
          "const": false
        }
      },
      "oneOf": [
        {
          "$ref": "#/$defs/executionAuditPayload"
        },
        {
          "$ref": "#/$defs/executionAuditListPayload"
        },
        {
          "$ref": "#/$defs/executionAuditErrorPayload"
        }
      ],
      "additionalProperties": true
    },
    "writeReadinessStatus": {
      "type": "string",
      "enum": ["ready", "blocked", "unknown"]
    },
    "writeReadinessCategory": {
      "type": "string",
      "enum": ["approval", "precondition", "permission", "trace", "policy", "ci", "repo_state", "unknown"]
    },
    "writeReadinessCheckStatus": {
      "type": "string",
      "enum": ["pass", "blocked", "unknown"]
    },
    "writeReadinessSource": {
      "type": "string",
      "enum": ["audit_bundle", "preflight"]
    },
    "writeReadinessBlocker": {
      "type": "object",
      "required": ["category", "code", "message", "source"],
      "properties": {
        "category": {
          "$ref": "#/$defs/writeReadinessCategory"
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/writeReadinessSource"
        }
      },
      "additionalProperties": true
    },
    "writeReadinessCheck": {
      "type": "object",
      "required": ["category", "status", "code", "message", "source"],
      "properties": {
        "category": {
          "$ref": "#/$defs/writeReadinessCategory"
        },
        "status": {
          "$ref": "#/$defs/writeReadinessCheckStatus"
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/writeReadinessSource"
        }
      },
      "additionalProperties": true
    },
    "writeReadinessInputs": {
      "type": "object",
      "required": ["auditBundle", "preflight"],
      "properties": {
        "auditBundle": {
          "const": "available"
        },
        "preflight": {
          "type": "string",
          "enum": ["missing", "partial", "available"]
        }
      },
      "additionalProperties": true
    },
    "writeReadinessPayload": {
      "type": "object",
      "required": [
        "readinessStatus",
        "ready",
        "intentId",
        "runId",
        "planId",
        "approvalId",
        "blockers",
        "checks",
        "inputs",
        "executionEnabled",
        "writeExecution",
        "hasExecutionResults"
      ],
      "properties": {
        "readinessStatus": {
          "$ref": "#/$defs/writeReadinessStatus"
        },
        "ready": {
          "type": "boolean"
        },
        "intentId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "planId": {
          "type": "string"
        },
        "approvalId": {
          "type": "string"
        },
        "checkpointId": {
          "type": "string"
        },
        "blockers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/writeReadinessBlocker"
          }
        },
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/writeReadinessCheck"
          }
        },
        "inputs": {
          "$ref": "#/$defs/writeReadinessInputs"
        },
        "executionEnabled": {
          "const": false
        },
        "writeExecution": {
          "const": "disabled"
        },
        "hasExecutionResults": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "writeReadinessErrorPayload": {
      "type": "object",
      "required": ["status", "errorCode", "message", "readiness", "executionEnabled", "writeExecution", "hasExecutionResults"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_found", "error"]
        },
        "errorCode": {
          "type": "string",
          "enum": [
            "write_readiness_missing_intent",
            "write_readiness_intent_not_found",
            "invalid_execution_intent_file",
            "invalid_execution_trace_file",
            "write_readiness_preflight_unsupported"
          ]
        },
        "message": {
          "type": "string"
        },
        "intentId": {
          "type": "string"
        },
        "readiness": {
          "const": null
        },
        "details": {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["execution_intent", "execution_trace", "preflight"]
            }
          },
          "additionalProperties": true
        },
        "executionEnabled": {
          "const": false
        },
        "writeExecution": {
          "const": "disabled"
        },
        "hasExecutionResults": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "ownerDecisionItem": {
      "type": "object",
      "required": ["source", "reason"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["reviewer", "graph", "context"]
        },
        "reason": {
          "type": "string"
        },
        "subtaskId": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "prExecPayload": {
      "type": "object",
      "required": [
        "id",
        "planId",
        "runId",
        "mode",
        "status",
        "blockedReasons",
        "commandCandidates",
        "executedCommands",
        "message",
        "createdAt"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "planId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["dry-run", "execute"]
        },
        "status": {
          "type": "string",
          "enum": ["dry_run", "ready", "blocked"]
        },
        "approval": {
          "$ref": "#/$defs/approvalRecord"
        },
        "blockedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commandCandidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/prPlanCommandCandidate"
          }
        },
