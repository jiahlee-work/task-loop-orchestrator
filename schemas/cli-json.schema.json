{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jiahlee-work/task-loop-orchestrator/schemas/cli-json.schema.json",
  "title": "task-loop-orchestrator CLI JSON response",
  "description": "Common metadata envelope for task-loop-orchestrator CLI --json responses. Command-specific payload fields are allowed at the top level for compatibility.",
  "type": "object",
  "required": ["schemaVersion", "command", "createdAt"],
  "properties": {
    "schemaVersion": {
      "const": 1,
      "description": "CLI JSON schema version."
    },
    "command": {
      "type": "string",
      "enum": [
        "init",
        "doctor",
        "run",
        "resume",
        "status",
        "checkpoint",
        "checks",
        "pr-plan",
        "pr-exec",
        "approve-pr"
      ],
      "description": "CLI command that produced the response."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp for the JSON response. Legacy payload timestamps may be preserved."
    }
  },
  "$defs": {
    "runStatus": {
      "type": "string",
      "enum": ["created", "running", "completed", "blocked", "failed"]
    },
    "permissionMode": {
      "type": "string",
      "enum": ["read", "write", "maintainer"]
    },
    "doctorStatus": {
      "type": "string",
      "enum": ["pass", "warn", "fail"]
    },
    "doctorSuggestion": {
      "type": "object",
      "required": ["label", "command", "reason", "destructive"],
      "properties": {
        "label": {
          "type": "string"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        },
        "destructive": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "doctorCheck": {
      "type": "object",
      "required": ["id", "status", "summary"],
      "properties": {
        "id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/doctorStatus"
        },
        "summary": {
          "type": "string"
        },
        "details": {},
        "recommendedAction": {
          "type": "string"
        },
        "suggestions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/doctorSuggestion"
          }
        }
      },
      "additionalProperties": true
    },
    "doctorPayload": {
      "type": "object",
      "required": ["status", "rootDir", "githubMode", "checks"],
      "properties": {
        "status": {
          "$ref": "#/$defs/doctorStatus"
        },
        "rootDir": {
          "type": "string"
        },
        "githubMode": {
          "type": "string",
          "enum": ["none", "gh-cli"]
        },
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/doctorCheck"
          }
        }
      },
      "additionalProperties": true
    },
    "githubCheckStatus": {
      "type": "string",
      "enum": ["success", "pending", "failure", "error", "not_found", "unknown"]
    },
    "checkpointStatus": {
      "type": "string",
      "enum": ["clean", "needs_attention", "blocked"]
    },
    "checkpointCounts": {
      "type": "object",
      "required": ["completed", "blocked", "pending", "active", "failed"],
      "properties": {
        "completed": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        },
        "pending": {
          "type": "integer",
          "minimum": 0
        },
        "active": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "checkDetail": {
      "type": "object",
      "required": ["name", "status"],
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/githubCheckStatus"
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "checkpointCiCheck": {
      "type": "object",
      "required": ["status", "summary", "source"],
      "properties": {
        "status": {
          "anyOf": [
            {
              "$ref": "#/$defs/githubCheckStatus"
            },
            {
              "const": "not_run"
            }
          ]
        },
        "summary": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": ["placeholder", "github"]
        },
        "details": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/checkDetail"
          }
        }
      },
      "additionalProperties": true
    },
    "maintainerActionCandidate": {
      "type": "object",
      "required": ["action", "label", "reason", "decisionReady"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["push", "merge_pr", "jira_transition", "release", "create_pr"]
        },
        "label": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "decisionReady": {
          "const": true
        }
      },
      "additionalProperties": true
    },
    "prPlanCommandCandidate": {
      "type": "object",
      "required": ["action", "command", "reason", "decisionReady"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["create_branch", "commit", "push", "create_pr"]
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        },
        "decisionReady": {
          "const": true
        }
      },
      "additionalProperties": true
    },
    "approvalPlanSnapshot": {
      "type": "object",
      "required": ["planTitle", "baseBranch", "sourceBranchHint", "blockedReasons", "commandCandidateActions"],
      "properties": {
        "planTitle": {
          "type": "string"
        },
        "baseBranch": {
          "type": "string"
        },
        "sourceBranchHint": {
          "type": "string"
        },
        "blockedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commandCandidateActions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["create_branch", "commit", "push", "create_pr"]
          }
        }
      },
      "additionalProperties": true
    },
    "approvalRecord": {
      "type": "object",
      "required": ["id", "scope", "planId", "runId", "status", "createdAt"],
      "properties": {
        "id": {
          "type": "string"
        },
        "scope": {
          "const": "pr_execution"
        },
        "planId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "checkpointId": {
          "type": "string"
        },
        "planSnapshot": {
          "$ref": "#/$defs/approvalPlanSnapshot"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"]
        },
        "approvedBy": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "approvePrPayload": {
      "$ref": "#/$defs/approvalRecord"
    },
    "ownerDecisionItem": {
      "type": "object",
      "required": ["source", "reason"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["reviewer", "graph", "context"]
        },
        "reason": {
          "type": "string"
        },
        "subtaskId": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "prExecPayload": {
      "type": "object",
      "required": [
        "id",
        "planId",
        "runId",
        "mode",
        "status",
        "blockedReasons",
        "commandCandidates",
        "executedCommands",
        "message",
        "createdAt"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "planId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["dry-run", "execute"]
        },
        "status": {
          "type": "string",
          "enum": ["dry_run", "ready", "blocked"]
        },
        "approval": {
          "$ref": "#/$defs/approvalRecord"
        },
        "blockedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commandCandidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/prPlanCommandCandidate"
          }
        },
        "executedCommands": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "message": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "prPlanPayload": {
      "type": "object",
      "required": [
        "id",
        "runId",
        "sourceBranchHint",
        "baseBranch",
        "title",
        "body",
        "preconditions",
        "blockedReasons",
        "commandCandidates",
        "createdAt"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "checkpointId": {
          "type": "string"
        },
        "sourceBranchHint": {
          "type": "string"
        },
        "baseBranch": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockedReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commandCandidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/prPlanCommandCandidate"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "checkpointPayload": {
      "type": "object",
      "required": [
        "id",
        "runId",
        "status",
        "counts",
        "repoStatus",
        "diffStat",
        "ciCheck",
        "conflictRisks",
        "recommendedNextAction",
        "maintainerActionCandidates",
        "ownerDecisionItems",
        "createdAt"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/checkpointStatus"
        },
        "counts": {
          "$ref": "#/$defs/checkpointCounts"
        },
        "repoStatus": {
          "type": "string"
        },
        "diffStat": {
          "type": "string"
        },
        "ciCheck": {
          "$ref": "#/$defs/checkpointCiCheck"
        },
        "conflictRisks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommendedNextAction": {
          "type": "string"
        },
        "maintainerActionCandidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/maintainerActionCandidate"
          }
        },
        "ownerDecisionItems": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ownerDecisionItem"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "checksPayload": {
      "type": "object",
      "required": ["status", "summary", "source"],
      "properties": {
        "status": {
          "$ref": "#/$defs/githubCheckStatus"
        },
        "summary": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "source": {
          "const": "github"
        },
        "details": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/checkDetail"
          }
        }
      },
      "additionalProperties": true
    },
    "subtaskCounts": {
      "type": "object",
      "required": ["pending", "active", "completed", "blocked", "failed", "total"],
      "properties": {
        "pending": {
          "type": "integer",
          "minimum": 0
        },
        "active": {
          "type": "integer",
          "minimum": 0
        },
        "completed": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "runReportTask": {
      "type": "object",
      "required": ["id", "title", "acceptanceCriteria"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "acceptanceCriteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "runReportPayload": {
      "type": "object",
      "required": ["runId", "status", "iterations", "permissionMode", "task", "counts", "savedPath", "run"],
      "properties": {
        "runId": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/runStatus"
        },
        "iterations": {
          "type": "integer",
          "minimum": 0
        },
        "permissionMode": {
          "$ref": "#/$defs/permissionMode"
        },
        "task": {
          "$ref": "#/$defs/runReportTask"
        },
        "counts": {
          "$ref": "#/$defs/subtaskCounts"
        },
        "savedPath": {
          "type": "string"
        },
        "run": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "command": {
            "enum": ["run", "resume"]
          }
        },
        "required": ["command"]
      },
      "then": {
        "$ref": "#/$defs/runReportPayload"
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "status"
          }
        },
        "required": ["command", "runId"]
      },
      "then": {
        "$ref": "#/$defs/runReportPayload"
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "checks"
          }
        },
        "required": ["command"]
      },
      "then": {
        "$ref": "#/$defs/checksPayload"
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "checkpoint"
          }
        },
        "required": ["command", "id"]
      },
      "then": {
        "$ref": "#/$defs/checkpointPayload"
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "pr-plan"
          }
        },
        "required": ["command", "id"]
      },
      "then": {
        "$ref": "#/$defs/prPlanPayload"
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "pr-exec"
          }
        },
        "required": ["command", "id"]
      },
      "then": {
        "$ref": "#/$defs/prExecPayload"
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "approve-pr"
          }
        },
        "required": ["command", "id"]
      },
      "then": {
        "$ref": "#/$defs/approvePrPayload"
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "doctor"
          }
        },
        "required": ["command"]
      },
      "then": {
        "$ref": "#/$defs/doctorPayload"
      }
    }
  ],
  "additionalProperties": true
}
